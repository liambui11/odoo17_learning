<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="action_hospital_patient_readonly_tree"
            model="ir.ui.view">
        <field name="name">hospital.patient.tree</field>
        <field name="model">hospital.patient</field>
        <field name="arch"
               type="xml">
            <tree string="Patients" create="0" delete="0" edit="0">
                <field name="name"/>
                <field name="date_of_birth" optional="show"/>
                <field name="gender" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="action_hospital_patient_readonly_form"
            model="ir.ui.view">
        <field name="name">hospital.patient.form</field>
        <field name="model">hospital.patient</field>
        <field name="arch"
               type="xml">
            <form string="Patients View" create="0" delete="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="date_of_birth"/>
                        </group>
                        <group>
                            <field name="gender"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="action_hospital_patient_readonly"
            model="ir.actions.act_window">
        <field name="name">Patients View</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[Command.clear(),
                          (0,0,{'view_mode':'tree', 'view_id': ref('action_hospital_patient_readonly_tree')}),
                          (0,0,{'view_mode':'form', 'view_id': ref('action_hospital_patient_readonly_form')})]"/>
        <field name="help"
               type="html">
            <p class="o_view_nocotent_smiling_face">
                Create a new patient
            </p>
        </field>
    </record>
</odoo>